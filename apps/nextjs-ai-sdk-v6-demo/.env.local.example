# Copy this file to `.env.local` and fill in real values.
# `.env.local` is ignored by git.

# Required: AI provider
ANTHROPIC_API_KEY=your_anthropic_api_key

# Required: database connection (URL-encode special chars in password)
# Docker Compose uses CLICKHOUSE_PASSWORD env var; keep this in sync.
AI_SPANS_DATABASE_URL=http://default:clickhouse_password@localhost:8123/ai_spans

# Optional ai-spans overrides (defaults are usually fine)
# AI_SPANS_STORAGE_BACKEND=clickhouse
# AI_SPANS_SERVICE_NAME=ai-spans-nextjs-example
# AI_SPANS_ENV=local
# AI_SPANS_CONTENT_MODE=full

# Optional debugging (uncomment when needed)
# AI_SPANS_PROCESSOR_MODE=serverless
# AI_SPANS_DEBUG=1
